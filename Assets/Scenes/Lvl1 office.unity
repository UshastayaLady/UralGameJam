  m_Text: "\u0410 \u0432\u043E\u0442 \u0438 \u0438\u0441\u043A\u043E\u043C\u0430\u044F
    \u0443\u043B\u0438\u043A\u0430! \u0418 \u043A\u0442\u043E \u0436\u0435 \u0442\u0443\u0442
    \u0443 \u043D\u0430\u0441 \u043F\u043B\u043E\u0445\u0438\u0448? \u0414\u0430
    \u044D\u0442\u043E \u0436\u0435 \u043E\u0434\u043D\u0430 \u0438\u0437 \u0448\u0438\u0448\u043A\u043E\u043C
    \u043C\u0438\u043D\u0438\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u0430 \u043C\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0439! \u041D\u0443\u0436\u043D\u043E
    \u0434\u043E\u043B\u043E\u0436\u0438\u0442\u044C \u043E\u0431 \u044D\u0442\u043E\u043C
    \u0441\u0440\u0430\u0437\u0443, \u043A\u0430\u043A \u0432\u0435\u0440\u043D\u0443\u0441\u044C."
